{
  "name": "@worldbookllm/server",
  "private": true,
  "version": "0.0.0",
  "license": "AGPL-3.0-only",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc && esbuild src/index.ts src/app.ts --bundle --platform=node --format=esm --target=node20 --packages=external --alias:@worldbookllm/shared=../../packages/shared/src/index.ts --alias:@worldbookllm/providers=../../packages/providers/src/index.ts --outdir=dist",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@fastify/multipart": "10.1.0",
    "@worldbookllm/providers": "workspace:*",
    "@worldbookllm/shared": "workspace:*",
    "better-sqlite3": "12.11.1",
    "fastify": "^5.4.0",
    "gray-matter": "4.0.3",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "7.6.13",
    "@types/node": "^26.1.1",
    "@vitest/coverage-v8": "^4.1.10",
    "esbuild": "0.28.1",
    "tsx": "^4.23.1",
    "typescript": "^5.9.0",
    "vitest": "^4.1.10"
  }
}
